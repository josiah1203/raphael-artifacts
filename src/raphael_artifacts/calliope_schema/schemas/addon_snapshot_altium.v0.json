{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calliope.dev/schemas/addon-snapshot/altium/v0",
  "title": "Altium Addon Snapshot",
  "type": "object",
  "required": ["document_id"],
  "additionalProperties": true,
  "properties": {
    "document_id": {"type": "string", "minLength": 1},
    "board_id": {"type": "string"},
    "document_name": {"type": "string"},
    "project_id": {"type": "string"},
    "tool_identifier": {"type": "string", "const": "altium"},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string"},
          "component_id": {"type": "string"}
        }
      }
    },
    "components": {
      "type": "array",
      "items": {"type": "object"}
    }
  },
  "anyOf": [
    {"required": ["changes"], "properties": {"changes": {"minItems": 1}}},
    {"required": ["components"], "properties": {"components": {"minItems": 1}}}
  ]
}
