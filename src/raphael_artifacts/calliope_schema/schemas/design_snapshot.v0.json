{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://calliope.dev/schemas/design-snapshot/v0",
  "title": "Fusion Design Snapshot",
  "type": "object",
  "required": ["document_id", "document_name", "captured_at_utc"],
  "additionalProperties": true,
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "document_name": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "captured_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "path_hash": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "adapter_version": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "timeline_index": { "type": "integer" },
          "is_suppressed": { "type": "boolean" },
          "properties": { "type": "object" }
        }
      }
    },
    "materials": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "appearance": { "type": "string" }
        }
      }
    },
    "configurations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    },
    "assembly_joints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "occurrence_one": { "type": ["string", "null"] },
          "occurrence_two": { "type": ["string", "null"] }
        }
      }
    }
  }
}
